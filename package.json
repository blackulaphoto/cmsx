{
  "name": "case_manager_suite2",
  "version": "1.0.0",
  "description": "A comprehensive case management platform for reentry services, consolidating the best features from multiple codebases.",
  "main": "index.js",
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "test": "playwright test",
    "test:e2e:ur": "python scripts/run_ur_e2e.py",
    "test:e2e:documentation": "python scripts/run_documentation_e2e.py",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "typecheck": "npm --prefix frontend run typecheck"
  },
  "keywords": [],
