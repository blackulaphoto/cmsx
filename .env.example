# Core app
PORT=8000
DEBUG=False
HOST=0.0.0.0

# Security
SECRET_KEY=change-this-in-production
JWT_SECRET_KEY=change-this-in-production

# CORS (comma-separated)
# Example:
# CORS_ORIGINS=https://your-frontend.vercel.app,https://www.yourdomain.com
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# AI / external APIs
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=2000

GOOGLE_API_KEY=
GOOGLE_CSE_ID=
GOOGLE_JOBS_CSE_ID=
GOOGLE_HOUSING_CSE_ID=
CUSTOM_SEARCH_ENGINE_ID=
SERPAPI_API_KEY=
SERPER_API_KEY=

# Database
# Default remains SQLite for module compatibility.
# For Railway Postgres migration workstreams, set DATABASE_URL accordingly.
# Example:
# DATABASE_URL=postgresql://postgres:password@host:5432/railway
DATABASE_URL=sqlite:///databases/case_management.db

# Frontend runtime (Vercel)
# Keep blank to use same-origin /api rewrites.
VITE_API_BASE_URL=

# Firebase web SDK (this frontend uses Vite, so use the VITE_ prefix)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Firebase Admin SDK for backend token verification
# Set exactly one of these in deployment. JSON is preferred on Vercel.
FIREBASE_ADMIN_SERVICE_ACCOUNT_JSON=
FIREBASE_ADMIN_SERVICE_ACCOUNT_PATH=
FIREBASE_PROJECT_ID=

# Comma-separated emails that should be granted admin role on first profile registration.
AUTH_ADMIN_EMAILS=
