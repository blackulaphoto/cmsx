# Core app
PORT=8000
DEBUG=False
HOST=0.0.0.0

# Security
SECRET_KEY=change-this-in-production
JWT_SECRET_KEY=change-this-in-production

# CORS (comma-separated)
# Example:
# CORS_ORIGINS=https://your-frontend.vercel.app,https://www.yourdomain.com
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# AI / external APIs
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=2000
DEEPGRAM_API_KEY=

GOOGLE_API_KEY=
GOOGLE_CSE_ID=
GOOGLE_JOBS_CSE_ID=
GOOGLE_HOUSING_CSE_ID=
CUSTOM_SEARCH_ENGINE_ID=
SERPAPI_API_KEY=
SERPER_API_KEY=

# Database
# Default remains SQLite for module compatibility.
# For Railway Postgres migration workstreams, set DATABASE_URL accordingly.
# Example:
# DATABASE_URL=postgresql://postgres:password@host:5432/railway
DATABASE_URL=sqlite:///databases/case_management.db

# Frontend runtime (Vercel)
# Keep blank to use same-origin /api rewrites.
VITE_API_BASE_URL=
# Direct Railway fallback used when same-origin Vercel rewrites fail for safe GET/HEAD requests.
VITE_RAILWAY_PUBLIC_URL=
# Set to 1 to bypass same-origin /api rewrites on Vercel and call VITE_API_BASE_URL directly.
VITE_FORCE_DIRECT_API=
# Frontend API request timeout in milliseconds.
VITE_API_TIMEOUT_MS=8000

# Firebase web SDK (this frontend uses Vite, so use the VITE_ prefix)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Firebase Admin SDK for backend token verification
# Set exactly one of these in deployment. JSON is preferred on Vercel.
FIREBASE_ADMIN_SERVICE_ACCOUNT_JSON=
FIREBASE_ADMIN_SERVICE_ACCOUNT_PATH=
FIREBASE_PROJECT_ID=

# Comma-separated emails that should be granted admin role on first profile registration.
AUTH_ADMIN_EMAILS=

# Local/test-only auth harness. Never enable in production.
# Requires ENABLE_TEST_AUTH=true and APP_ENV=test/testing/e2e.
APP_ENV=
ENABLE_TEST_AUTH=false
# Optional local-only UR database for browser E2E. Ignored unless test auth is enabled.
UR_TEST_DATABASE_URL=sqlite:///./temp/ur-e2e.db

# Frontend E2E auth harness. Backend still ignores these headers unless ENABLE_TEST_AUTH is safely enabled.
VITE_ENABLE_TEST_AUTH=false
VITE_TEST_AUTH_USER=uid-e2e
VITE_TEST_AUTH_EMAIL=e2e.case.manager@example.com
VITE_TEST_AUTH_NAME=E2E Case Manager
VITE_TEST_AUTH_ROLE=admin
VITE_TEST_AUTH_CASE_MANAGER=cm_e2e

# Sober Living Directory scheduler
SOBER_LIVING_DIRECTORY_SCHEDULER_POLL_SECONDS=300
SOBER_LIVING_DIRECTORY_SCHEDULER_MAX_JOBS_PER_CYCLE=3
SOBER_LIVING_DIRECTORY_SCHEDULER_AUTOSTART=false
